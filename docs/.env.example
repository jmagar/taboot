# LlamaCrawl Environment Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# =============================================================================
# DATA SOURCE CREDENTIALS
# =============================================================================

# Firecrawl Web Scraping Service
# Get API key from your Firecrawl instance admin panel
FIRECRAWL_API_URL=https://firecrawl.tootie.tv
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub API Access
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:discussion
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reddit API Access
# Create an app at: https://www.reddit.com/prefs/apps
# Choose "script" app type
REDDIT_CLIENT_ID=xxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=LlamaCrawl/1.0

# Gmail API Access (OAuth 2.0)
# 1. Create a Google Cloud Project: https://console.cloud.google.com/
# 2. Enable Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Download credentials.json
# 5. Run OAuth flow to obtain refresh token (see docs/configuration.md)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Elasticsearch Access
# Get API key from Elasticsearch admin console
# Or use basic auth: http://username:password@host:port
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# INFRASTRUCTURE URLS
# =============================================================================

# Qdrant Vector Database
# Default: http://localhost:7000
QDRANT_URL=http://localhost:7000

# Neo4j Graph Database
# Default: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Redis State/Cache/DLQ
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# TEI Embedding Service (Qwen3-Embedding-0.6B)
# Default: http://localhost:8080
TEI_EMBEDDING_URL=http://localhost:8080

# TEI Reranker Service (Qwen3-Reranker-0.6B)
# Default: http://localhost:8081
TEI_RERANKER_URL=http://localhost:8081

# Ollama LLM Service
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# =============================================================================
# OBSERVABILITY SETTINGS
# =============================================================================

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Prometheus Metrics Port
# Default: 9090 (set to 0 to disable)
PROMETHEUS_PORT=9090
